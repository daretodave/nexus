# Copy this file to .env and fill in the values.
# .env is gitignored; never commit it.

# ============================================================
# DEPLOY GATE — pick a provider, set DEPLOY_PROVIDER
# ============================================================

# Provider for scripts/deploy-check.mjs.
# Supported: netlify | vercel | github-actions | health-check | none
# DEPLOY_PROVIDER=netlify

# --- NETLIFY ------------------------------------------------
# NETLIFY_AUTH_TOKEN=nfp_...                  # https://app.netlify.com/user/applications
# NETLIFY_SITE_NAME=<PROJECT_LOWER>           # defaults to "<PROJECT_LOWER>"

# --- VERCEL -------------------------------------------------
# VERCEL_TOKEN=...                            # https://vercel.com/account/tokens
# VERCEL_PROJECT_ID=prj_...
# VERCEL_TEAM_ID=team_...                     # if a team-owned project

# --- GITHUB ACTIONS (any provider via Actions) --------------
# GH_TOKEN=github_pat_...                     # see GH_TOKEN below — same value
# DEPLOY_WORKFLOW=deploy.yml                  # filename in .github/workflows/

# --- HEALTH CHECK (self-hosted) -----------------------------
# HEALTH_CHECK_URL=https://yoursite.example.com/healthz
# HEALTH_CHECK_EXPECT=200                     # or a sentinel string
# DEPLOY_WAIT_BUFFER_S=120                    # seconds to wait before probing

# ============================================================
# GITHUB — issue mirror + triage (loop-issue.mjs + /triage)
# ============================================================

# Repo-scoped PAT used by:
#   - scripts/loop-issue.mjs (the autonomous-loop issue mirror)
#   - skills/triage.md (inbound user-issue review)
#   - skills/iterate.md Step 2.5 (per-finding mirror)
#   - skills/ship-a-phase.md Step 2.5 + plan-a-phase.md Step 5.5
#     (per-phase mirror — phase-open opens at start, phase-close
#      posts the deploy URL after green deploy; the commit's
#      `Closes #N` trailer auto-closes on push)
#
# `gh` CLI auto-reads GH_TOKEN.
# Needs: Issues read+write, Metadata read.
# Get one at: https://github.com/settings/tokens
# GH_TOKEN=github_pat_...

# Repo slug for /triage and the loop mirror. Defaults to <REPO_SLUG>.
# Override if running the loop against a fork.
# GH_REPO=<REPO_SLUG>

# ============================================================
# CRITIQUE — auth-aware /critique (only if your app has a login wall)
# ============================================================

# Tells `reader` how to establish a session before walking the
# authenticated page set. Must match `Auth:` in plan/bearings.md.
# Supported: none | test-user | session-cookie | bearer-token
#            | shared-secret | preview-env | magic-link
# Default if unset: critique runs anonymous only.
# See nexus/customization/auth-aware-critique.md for full design.
# CRITIQUE_AUTH_MODE=session-cookie

# --- A. test-user (real login flow; true E2E fidelity) ------
# CRITIQUE_AUTH_LOGIN_URL=https://yourapp.example/login
# CRITIQUE_AUTH_USERNAME=critique-bot@example.com
# CRITIQUE_AUTH_PASSWORD=<long-random>
# CRITIQUE_AUTH_USERNAME_SELECTOR=input[name="email"]
# CRITIQUE_AUTH_PASSWORD_SELECTOR=input[name="password"]
# CRITIQUE_AUTH_SUBMIT_SELECTOR=button[type="submit"]
# CRITIQUE_AUTH_SUCCESS_SELECTOR=[data-testid="user-menu"]

# --- B. session-cookie (recommended default; cloud-loop friendly)
# Full Cookie header value, semicolon-separated. Refresh out-of-band
# when the loop reports auth-failed.
# CRITIQUE_SESSION_COOKIE=session=eyJ...; csrf=abc123

# --- B'. bearer-token (token-auth variant of session-cookie)
# CRITIQUE_BEARER_TOKEN=eyJhbGciOi...

# --- C. shared-secret (dev-mode impersonation header)
# Server-side check honors this header; only enabled outside prod
# OR only honored when secret matches. See customization doc for
# hardening.
# CRITIQUE_BOT_HEADER=X-Critique-Bot
# CRITIQUE_BOT_SECRET=<long-random-rotated-like-prod-cred>

# --- D. preview-env (point critique at a preview deploy)
# CRITIQUE_PREVIEW_URL=https://your-branch--your-app.preview.dev
# Optional basic-auth on the preview itself:
# CRITIQUE_PREVIEW_BASIC_USER=preview
# CRITIQUE_PREVIEW_BASIC_PASS=<long-random>

# --- E. magic-link (passwordless apps with a controlled mailbox)
# CRITIQUE_AUTH_LOGIN_URL=https://yourapp.example/login
# CRITIQUE_AUTH_USERNAME=critique-bot@yourdomain.example
# CRITIQUE_MAILBOX_API_URL=https://api.mailbox-provider.example/v1/inbox
# CRITIQUE_MAILBOX_API_TOKEN=<api-token>
# CRITIQUE_MAGIC_LINK_SENDER=noreply@yourapp.example
