# Copy this file to .env and fill in the values.
# .env is gitignored; never commit it.

# ============================================================
# DEPLOY GATE — pick a provider, set DEPLOY_PROVIDER
# ============================================================

# Provider for scripts/deploy-check.mjs.
# Supported: netlify | vercel | github-actions | health-check | none
# DEPLOY_PROVIDER=netlify

# --- NETLIFY ------------------------------------------------
# NETLIFY_AUTH_TOKEN=nfp_...                  # https://app.netlify.com/user/applications
# NETLIFY_SITE_NAME=<PROJECT_LOWER>           # defaults to "<PROJECT_LOWER>"

# --- VERCEL -------------------------------------------------
# VERCEL_TOKEN=...                            # https://vercel.com/account/tokens
# VERCEL_PROJECT_ID=prj_...
# VERCEL_TEAM_ID=team_...                     # if a team-owned project

# --- GITHUB ACTIONS (any provider via Actions) --------------
# GH_TOKEN=github_pat_...                     # see GH_TOKEN below — same value
# DEPLOY_WORKFLOW=deploy.yml                  # filename in .github/workflows/

# --- HEALTH CHECK (self-hosted) -----------------------------
# HEALTH_CHECK_URL=https://yoursite.example.com/healthz
# HEALTH_CHECK_EXPECT=200                     # or a sentinel string
# DEPLOY_WAIT_BUFFER_S=120                    # seconds to wait before probing

# ============================================================
# TRIAGE — GitHub PAT for /triage and issue closing
# ============================================================

# Used by /triage to read + label + comment on issues.
# gh CLI auto-reads GH_TOKEN.
# Needs: Issues read+write, Metadata read.
# Get one at: https://github.com/settings/tokens
# GH_TOKEN=github_pat_...

# Repo slug for /triage. Defaults to <REPO_SLUG>.
# Override if running the loop against a fork.
# GH_REPO=<REPO_SLUG>
